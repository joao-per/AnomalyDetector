# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins allowed to call this API (your React dev server, etc.)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Dataverse (Stiegl DEV / Power Platform) ──────────────────────────────────
# Web API base of the environment (no trailing /api/...).
DATAVERSE_URL=https://stiegl-developerdefault.crm4.dynamics.com
DATAVERSE_API_VERSION=v9.2
# Entra app registration used for client-credentials auth to Dataverse.
DATAVERSE_TENANT_ID=dfe9186e-bd11-4b76-9d24-0dddd4a395c9
DATAVERSE_TOKEN_URL=https://login.microsoftonline.com/dfe9186e-bd11-4b76-9d24-0dddd4a395c9/oauth2/v2.0/token
DATAVERSE_CLIENT_ID=ce399769-0e86-4dfd-bc2f-960c5b1dcf9b
# SECRET — never commit. Put the (rotated!) client secret here locally / in Linode env.
DATAVERSE_CLIENT_SECRET=

# Article categories that must NEVER appear in the anomaly lists (comma-
# separated). Default: PFANDART (deposit articles, client request 2026-07-05).
# HIDDEN_ARTICLE_CATEGORIES=PFANDART

# ── Power Automate flow endpoints (HTTP triggers) ────────────────────────────
# Kill switch for the email endpoints (generate/send). While false they return
# HTTP 501. Status changes + signatures work regardless.
EMAIL_ACTIONS_ENABLED=true
# Email DRAFT generation (vendor + internal, AI). IMPORTANT: this must be the
# FULL trigger URL including the SAS params (…&sp=…&sv=1.0&sig=…) — copy it from
# the flow's "When an HTTP request is received" trigger in Power Automate.
# Without the signature Power Automate answers 401 DirectApiAuthorizationRequired
# and the backend falls back to a server-side template draft.
GENERATE_EMAIL_FLOW_URL=https://defaultdfe9186ebd114b769d240dddd4a395.c9.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/adfcbfdf8bab461092ee01eb53600161/triggers/manual/paths/invoke?api-version=1
# Email SENDING flows — if blank, the backend falls back to Microsoft Graph
# sendMail (set GRAPH_SENDER_UPN below). A flow URL takes precedence.
EXTERNAL_EMAIL_FLOW_URL=
INTERNAL_EMAIL_FLOW_URL=
# Status-change flows. Optional: if blank, the backend changes status by writing
# directly to Dataverse instead of calling the flow (recommended for Phase 1).
# Cancel → "abgebrochen"; Untrain → "Abtrainiert" (+ training-feedback insert).
SET_STATUS_IN_PROGRESS_FLOW_URL=
SET_STATUS_CANCELLED_FLOW_URL=
SET_STATUS_UNTRAINED_FLOW_URL=

# "Erklär mal": flow that explains the anomaly's plot image (at_testbildurl)
# via GPT vision. FULL trigger URL incl. the SAS params (…&sig=…) required.
EXPLAIN_ANOMALY_FLOW_URL=

# ── Microsoft Graph (email sending fallback) ─────────────────────────────────
# Mailbox the BFF sends from when no send-flow URL is set. Requires the app
# registration to hold the APPLICATION permission Mail.Send (admin consented).
# Leave blank to keep sending disabled (send endpoints then return 503).
GRAPH_SENDER_UPN=
# Override only if a separate app registration is used for Graph; otherwise the
# Dataverse client id/secret above are reused.
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Require a signed-in user (Django login session or Entra token) on every API
# endpoint except /api/health/ and /api/auth/*. Create accounts with
# `python manage.py createsuperuser` (or via the shell). Only disable for
# local experiments.
LOGIN_REQUIRED=true
# Entra ID SSO. When true, every request must carry an Entra Bearer token issued
# for ENTRA_API_AUDIENCE ("api://<api-client-id>"); the frontend signs users in
# with MSAL (see frontend/.env.example VITE_ENTRA_*). When false, the Phase-1
# X-User-Email header fallback applies — LOCAL DEV ONLY, never production.
ENTRA_AUTH_ENABLED=false
ENTRA_TENANT_ID=dfe9186e-bd11-4b76-9d24-0dddd4a395c9
ENTRA_API_AUDIENCE=
# Phase-1 fallback identity for local dev.
DEV_DEFAULT_USER_EMAIL=
