# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins allowed to call this API (your React dev server, etc.)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Dataverse (Stiegl DEV / Power Platform) ──────────────────────────────────
# Web API base of the environment (no trailing /api/...).
DATAVERSE_URL=https://stiegl-developerdefault.crm4.dynamics.com
DATAVERSE_API_VERSION=v9.2
# Entra app registration used for client-credentials auth to Dataverse.
DATAVERSE_TENANT_ID=dfe9186e-bd11-4b76-9d24-0dddd4a395c9
DATAVERSE_TOKEN_URL=https://login.microsoftonline.com/dfe9186e-bd11-4b76-9d24-0dddd4a395c9/oauth2/v2.0/token
DATAVERSE_CLIENT_ID=ce399769-0e86-4dfd-bc2f-960c5b1dcf9b
# SECRET — never commit. Put the (rotated!) client secret here locally / in Linode env.
DATAVERSE_CLIENT_SECRET=

# ── Power Automate flow endpoints (HTTP triggers) ────────────────────────────
# Email actions (generate/send) are DEFERRED until the approach is decided.
# While false, the email endpoints return HTTP 501. Status changes + signatures work regardless.
EMAIL_ACTIONS_ENABLED=false
# Email DRAFT generation (vendor + internal). URL is known from backendLogic.docx.
GENERATE_EMAIL_FLOW_URL=https://defaultdfe9186ebd114b769d240dddd4a395.c9.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/adfcbfdf8bab461092ee01eb53600161/triggers/manual/paths/invoke?api-version=1
# Email SENDING flows — NEED HTTP-trigger URLs from Power Automate (currently unknown).
# Leave blank to disable the send endpoints until you provide them.
EXTERNAL_EMAIL_FLOW_URL=
INTERNAL_EMAIL_FLOW_URL=
# Status-change flows. Optional: if blank, the backend changes status by writing
# directly to Dataverse instead of calling the flow (recommended for Phase 1).
SET_STATUS_IN_PROGRESS_FLOW_URL=
SET_STATUS_CANCELLED_FLOW_URL=

# ── Auth (Phase 1) ───────────────────────────────────────────────────────────
# Until Entra SSO is wired, the acting user's email arrives via the X-User-Email
# header; this is the fallback for local dev. REPLACE with real SSO for prod.
DEV_DEFAULT_USER_EMAIL=
