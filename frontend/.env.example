# Base URL of the Django backend-for-frontend (BFF). Include the /api suffix.
# IMPORTANT: use the SAME host the frontend is served from (e.g. both
# "localhost", or both the server IP) — the login session cookie is
# SameSite=Lax, so it is only sent when frontend and API share the host.
VITE_API_BASE_URL=http://localhost:8000/api

# Phase-1 auth stub: the acting user's email is sent as the X-User-Email header.
# Used only while the VITE_ENTRA_* SSO config below is absent.
VITE_USER_EMAIL=jonater.jp@gmail.com

# ── Entra ID SSO (Phase 2) ───────────────────────────────────────────────────
# Set all three to activate MSAL sign-in (the backend then needs
# ENTRA_AUTH_ENABLED=true + ENTRA_API_AUDIENCE). Requires an SPA app
# registration in the Stiegl tenant with the API scope granted.
# VITE_ENTRA_CLIENT_ID=<spa-app-registration-client-id>
# VITE_ENTRA_TENANT_ID=dfe9186e-bd11-4b76-9d24-0dddd4a395c9
# VITE_ENTRA_API_SCOPE=api://<api-client-id>/access_as_user
